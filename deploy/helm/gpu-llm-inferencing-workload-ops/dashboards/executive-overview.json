            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "pointSize": 5,
            "axisGridShow": true,
            "axisBorderShow": false
          },
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "targets": [
        {
          "expr": "avg by (model) (vllm_ttft_seconds{cluster=\"$cluster\", model=~\"$model\"})",
          "legendFormat": "{{model}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true,
          "calcs": [
            "lastNotNull",
            "mean",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
