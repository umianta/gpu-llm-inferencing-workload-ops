        "w": 8,
        "x": 16,
        "y": 18
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "fillOpacity": 10,
            "showPoints": "never",
            "lineWidth": 2,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "pointSize": 5,
            "axisGridShow": true,
            "axisBorderShow": false
          },
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "targets": [
        {
          "expr": "avg by (model) (vllm_prefix_cache_hit_rate{cluster=\"$cluster\", model=~\"$model\"})",
          "legendFormat": "{{model}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
