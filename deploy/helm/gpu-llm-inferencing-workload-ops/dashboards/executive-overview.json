{
  "annotations": {
    "list": []
  },
  "editable": true,
  "schemaVersion": 39,
  "title": "GPU & LLM Workload Observability \u2014 Executive View",
  "tags": [
    "vllm",
    "llm-d",
    "executive",
    "gpu"
  ],
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "cluster",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(gpu_utilization, cluster)",
        "current": {
          "text": "dgx-spark",
          "value": "dgx-spark"
        },
        "refresh": 2
      },
      {
        "name": "model",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(vllm_requests_running{cluster=\"$cluster\"}, model)",
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "type": "text",
      "title": "",
      "gridPos": {
        "h": 3,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "mode": "markdown",
        "content": "## GPU & LLM Workload Observability \u2014 who's using your GPUs, how fast, and what it costs\n**\u2460 Demand** (how much each model is used) \u2192 **\u2461 Experience** (how fast it responds) \u2192 **\u2462 Supply** (GPU utilization, memory & cost) \u2192 **\u2463 Health** (power/temperature). The story: *demand drives GPU utilization and VRAM, which drive cost \u2014 while latency shows the user impact.*"
      },
      "fieldConfig": {
        "defaults": {}
      }
    },
    {
      "type": "row",
      "title": "\u2460 Overview \u2014 what's running and what it costs",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 3
      },
      "fieldConfig": {
        "defaults": {}
      }
    },
    {
      "title": "Models Serving",
      "type": "stat",
      "description": "Number of distinct models currently served.",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calc": "lastNotNull"
        },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value",
        "wideLayout": true
      },
      "targets": [
        {
          "expr": "count(count by (model) (vllm_requests_running{cluster=\"$cluster\"}))"
        }
      ]
    },
    {
      "title": "Est. GPU Cost (accrued)",
      "type": "stat",
      "description": "Active GPU-time x hourly rate. Only counts time the GPU is actually working.",
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 4,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calc": "lastNotNull"
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "value",
        "wideLayout": true
      },
      "targets": [
        {
          "expr": "sum(cost_gpu_usd_estimate_total{cluster=\"$cluster\"}) or vector(0)"
        }
      ]
    },
    {
      "title": "GPU Busy %",
      "type": "stat",
      "description": "Average GPU compute utilization across the fleet.",
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 9,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              },
              {
                "color": "green",
                "value": 20
              },
              {
                "color": "yellow",
                "value": 80
              },
              {
                "color": "red",
                "value": 95
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calc": "lastNotNull"
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "value",
        "wideLayout": true
      },
      "targets": [
        {
          "expr": "avg(gpu_utilization{cluster=\"$cluster\"}) * 100"
        }
      ]
    },
    {
      "title": "GPU Memory Used %",
      "type": "stat",
      "description": "How full GPU VRAM is. High = risk of out-of-memory / eviction.",
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 14,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 80
              },
              {
                "color": "red",
                "value": 92
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calc": "lastNotNull"
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "value",
        "wideLayout": true
      },
      "targets": [
        {
          "expr": "max(gpu_memory_used_percent{cluster=\"$cluster\"})"
        }
      ]
    },
    {
      "title": "Requests In Flight",
      "type": "stat",
      "description": "Requests currently running + waiting across all models.",
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 19,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "purple"
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calc": "lastNotNull"
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "value",
        "wideLayout": true
      },
      "targets": [
        {
          "expr": "sum(vllm_requests_running{cluster=\"$cluster\"}) + sum(vllm_requests_waiting{cluster=\"$cluster\"})"
        }
      ]
    },
    {
      "type": "row",
      "title": "\u2461 Demand \u2014 how much each model is used",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {}
      }
    },
    {
      "title": "Token Throughput by Model (tokens/sec)",
      "type": "timeseries",
      "description": "Output tokens generated per second, per model. This is the primary 'work done' signal.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 9
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 15,
            "showPoints": "never",
            "lineWidth": 2,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "pointSize": 5,
            "axisGridShow": true,
            "axisBorderShow": false
          },
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "targets": [
        {
          "expr": "sum by (model) (rate(vllm_tokens_generated_total{cluster=\"$cluster\", model=~\"$model\"}[5m]))",
          "legendFormat": "{{model}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true,
          "calcs": [
            "lastNotNull",
            "mean",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "title": "Requests: Running vs Waiting by Model",
      "type": "timeseries",
      "description": "Waiting requests climbing above running means the model is under-provisioned.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 9
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "pointSize": 5,
            "axisGridShow": true,
            "axisBorderShow": false
          },
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "targets": [
        {
          "expr": "sum by (model) (vllm_requests_running{cluster=\"$cluster\", model=~\"$model\"})",
          "legendFormat": "running \u00b7 {{model}}"
        },
        {
          "expr": "sum by (model) (vllm_requests_waiting{cluster=\"$cluster\", model=~\"$model\"})",
          "legendFormat": "waiting \u00b7 {{model}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true,
          "calcs": [
            "lastNotNull",
            "mean",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "type": "row",
      "title": "\u2462 Experience \u2014 how fast it responds (latency)",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 17
      },
      "fieldConfig": {
        "defaults": {}
      }
    },
    {
      "title": "Time To First Token by Model",
      "type": "timeseries",
      "description": "How long a user waits before the first token. Lower is better.",
