    {
      "title": "Inter-Token Latency by Model",
      "type": "timeseries",
      "description": "Time between output tokens (streaming smoothness). Lower is better.",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 18
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
