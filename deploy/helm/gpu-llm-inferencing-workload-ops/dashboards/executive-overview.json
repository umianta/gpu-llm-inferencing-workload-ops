          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "targets": [
        {
          "expr": "avg by (model) (vllm_itl_seconds{cluster=\"$cluster\", model=~\"$model\"})",
          "legendFormat": "{{model}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true,
          "calcs": [
            "lastNotNull",
